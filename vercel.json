{
  "version": 2,
  "outputDirectory": "public",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/index",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "zavorafashion.com"
        }
      ],
      "destination": "https://www.zavorafashion.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin-login.html"
    },
    {
      "source": "/admin/",
      "destination": "/admin-login.html"
    },
    {
      "source": "/affiliate",
      "destination": "/affiliate.html"
    },
    {
      "source": "/affiliate/",
      "destination": "/affiliate.html"
    },
    {
      "source": "/affiliate/login",
      "destination": "/affiliate-login.html"
    },
    {
      "source": "/affiliate/dashboard",
      "destination": "/affiliate-dashboard.html"
    },
    {
      "source": "/affiliate/submitted",
      "destination": "/affiliate-submitted.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/forgot-password",
      "destination": "/forgot-password.html"
    },
    {
      "source": "/sign-up",
      "destination": "/sign-up.html"
    },
    {
      "source": "/register",
      "destination": "/sign-up.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/my-account",
      "destination": "/my-account.html"
    },
    {
      "source": "/api/admin-login",
      "destination": "/api/admin?action=login"
    },
    {
      "source": "/api/admin-verify",
      "destination": "/api/admin?action=verify"
    },
    {
      "source": "/api/admin-session",
      "destination": "/api/admin?action=session"
    },
    {
      "source": "/api/admin-logout",
      "destination": "/api/admin?action=logout"
    },
    {
      "source": "/api/admin-stats",
      "destination": "/api/admin?action=stats"
    },
    {
      "source": "/api/orders",
      "destination": "/api/admin?action=orders"
    },
    {
      "source": "/api/rewards",
      "destination": "/api/admin?action=rewards"
    },
    {
      "source": "/api/auto-import-printful",
      "destination": "/api/admin?action=auto-import-printful"
    },
    {
      "source": "/api/affiliate-approval-email",
      "destination": "/api/admin?action=affiliate-approval-email"
    },
    {
      "source": "/api/send-newsletter-confirmation",
      "destination": "/api/auth?action=newsletter"
    },
    {
      "source": "/api/auth-change-password",
      "destination": "/api/auth?action=change-password"
    },
    {
      "source": "/api/auth-dashboard",
      "destination": "/api/auth?action=dashboard"
    },
    {
      "source": "/api/auth-forgot-start",
      "destination": "/api/auth?action=forgot-start"
    },
    {
      "source": "/api/auth-health",
      "destination": "/api/auth?action=health"
    },
    {
      "source": "/api/auth-login",
      "destination": "/api/auth?action=login"
    },
    {
      "source": "/api/auth-logout",
      "destination": "/api/auth?action=logout"
    },
    {
      "source": "/api/auth-session",
      "destination": "/api/auth?action=session"
    },
    {
      "source": "/api/auth-start",
      "destination": "/api/auth?action=start"
    },
    {
      "source": "/api/auth-update-profile",
      "destination": "/api/auth?action=update-profile"
    },
    {
      "source": "/api/auth-verify-otp",
      "destination": "/api/auth?action=verify-otp"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' https://www.paypal.com https://www.paypalobjects.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https://api.resend.com https://api.printful.com https://*.supabase.co https://*.paypal.com https://www.paypal.com https://*.paypalobjects.com; frame-src 'self' https://www.paypal.com; upgrade-insecure-requests"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(self)"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "unsafe-none"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "same-origin"
        }
      ]
    }
  ]
}
