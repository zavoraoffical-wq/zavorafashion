{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/admin.html",
      "destination": "/api/admin-page"
    },
    {
      "source": "/admin",
      "destination": "/api/admin-page"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
