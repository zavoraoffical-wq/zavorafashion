{
  "version": 2,
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "zavorafashion.com"
        }
      ],
      "destination": "https://www.zavorafashion.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin-login.html"
    },
    {
      "source": "/admin/",
      "destination": "/admin-login.html"
    },
    {
      "source": "/affiliate",
      "destination": "/affiliate.html"
    },
    {
      "source": "/affiliate/",
      "destination": "/affiliate.html"
    },
    {
      "source": "/affiliate/login",
      "destination": "/affiliate-login.html"
    },
    {
      "source": "/affiliate/dashboard",
      "destination": "/affiliate-dashboard.html"
    },
    {
      "source": "/affiliate/submitted",
      "destination": "/affiliate-submitted.html"
    },
    {
      "source": "/api/admin-login",
      "destination": "/api/admin?action=login"
    },
    {
      "source": "/api/admin-verify",
      "destination": "/api/admin?action=verify"
    },
    {
      "source": "/api/admin-session",
      "destination": "/api/admin?action=session"
    },
    {
      "source": "/api/admin-logout",
      "destination": "/api/admin?action=logout"
    },
    {
      "source": "/api/admin-stats",
      "destination": "/api/admin?action=stats"
    },
    {
      "source": "/api/orders",
      "destination": "/api/admin?action=orders"
    },
    {
      "source": "/api/rewards",
      "destination": "/api/admin?action=rewards"
    },
    {
      "source": "/api/auto-import-printful",
      "destination": "/api/admin?action=auto-import-printful"
    }
  ],
  "crons": [
    {
      "path": "/api/admin?action=auto-import-printful",
      "schedule": "0 8 * * *"
    }
  ],
  "functions": {
    "api/printful-products.js": {
      "maxDuration": 60
    },
    "api/admin.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' https://www.paypal.com https://www.paypalobjects.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https://api.resend.com https://api.printful.com https://*.supabase.co; frame-src 'self' https://www.paypal.com; upgrade-insecure-requests"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(self)"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "unsafe-none"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "same-origin"
        }
      ]
    }
  ]
}
