{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/admin.html",
      "destination": "/api/admin-page"
    },
    {
      "source": "/admin",
      "destination": "/api/admin-page"
    }
  ],
  "crons": [
    {
      "path": "/api/auto-import-printful",
      "schedule": "0 8 * * *"
    }
  ],
  "functions": {
    "api/auto-import-printful.js": {
      "maxDuration": 60
    },
    "api/printful-products.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
