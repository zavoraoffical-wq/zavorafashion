RESEND_API_KEY=re_your_new_resend_api_key_here
# Supabase server-side connection.
# Login, OTP, sessions, dashboard and affiliate data require the service-role key.
# Do not use publishable/anon keys for server auth storage.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DOCUMENTS_TABLE=app_documents
SUPABASE_PRODUCTS_TABLE=products
SUPABASE_ORDERS_TABLE=orders
# Optional direct Postgres connection; REST access above is sufficient for this app
SUPABASE_DB_URL=
